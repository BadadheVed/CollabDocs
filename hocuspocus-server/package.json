    "@hocuspocus/server": "^3.4.0",
    "axios": "^1.13.2",
    "chalk": "^5.3.0",
    "dotenv": "^16.4.5",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "9.0.2",
    "prom-client": "^15.1.3",
    "yjs": "^13.6.19"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "9.0.6",
    "@types/node": "^20.19.25",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "ts-node-dev": "2.0.0",
    "typescript": "5.6.2"
  }
}
