{
  "name": "collab-docs-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --require tsconfig-paths/register src/index.ts",
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "jest --runInBand",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1006.0",
    "@prisma/client": "5.20.0",
    "axios": "^1.13.2",
    "bcrypt": "5.1.1",
    "cors": "2.8.5",
    "dotenv": "16.4.5",
    "express": "4.19.2",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "9.0.2",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "pg": "8.12.0",
    "prom-client": "^15.1.3",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "uuid": "^14.0.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/bcrypt": "5.0.2",
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "9.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "20.11.30",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "jest": "^30.4.2",
    "prisma": "5.20.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node-dev": "2.0.0",
    "typescript": "^6.0.3"
  }
}
