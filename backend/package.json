{
  "name": "collab-docs-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only -r dotenv/config --require tsconfig-paths/register src/index.ts",
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1006.0",
    "axios": "^1.13.2",
    "bcrypt": "5.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "2.8.5",
    "dotenv": "16.4.5",
    "express": "4.19.2",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "9.0.2",
    "mongodb": "^7.2.0",
    "prom-client": "^15.1.3",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "5.6.2"
  },
  "devDependencies": {
    "@types/bcrypt": "5.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/jsonwebtoken": "9.0.6",
    "@types/node": "20.11.30",
    "ts-node-dev": "2.0.0"
